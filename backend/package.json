{
    "name": "dateclone-backend",
    "version": "1.0.0",
    "description": "DateClone Backend API",
    "main": "server.js",
    "type": "module",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --coverage",
        "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --runInBand --forceExit --coverage",
        "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --runInBand --forceExit",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch --runInBand"
    },
    "jest": {
        "testEnvironment": "node",
        "transform": {},
        "extensionsToTreatAsEsm": [],
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "routes/**/*.js",
            "services/**/*.js",
            "middleware/auth.js",
            "!**/node_modules/**"
        ],
        "coverageReporters": [
            "text",
            "lcov"
        ],
        "testTimeout": 30000,
        "verbose": true,
        "moduleNameMapper": {}
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cloudinary": "^1.40.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.5.2",
        "express-validator": "^7.0.0",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.6",
        "resend": "^4.0.0",
        "socket.io": "^4.8.3",
        "stripe": "^14.0.0"
    },
    "devDependencies": {
        "@jest/globals": "^30.4.1",
        "concurrently": "^10.0.3",
        "jest": "^30.4.2",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    }
}
