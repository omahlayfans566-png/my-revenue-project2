# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/dateclone
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dateclone
# Optional fallback if SRV DNS fails in your environment:
# MONGODB_URI_DIRECT=mongodb://username:password@host1:27017,host2:27017,host3:27017/dateclone?tls=true&authSource=admin&retryWrites=true&w=majority

# JWT Secret Key
JWT_SECRET=your_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# Email Configuration
# ── Option 1: Resend (RECOMMENDED for production) ────────────────────────────
# Free 3,000 emails/month. Sign up at https://resend.com
# 1. Create API key at https://resend.com/api-keys
# 2. For production, verify your domain at https://resend.com/domains
# 3. Set EMAIL_FROM to your verified domain address
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=DateClone <noreply@yourdomain.com>

# ── Option 2: SMTP / Gmail (fallback when RESEND_API_KEY is empty) ───────────
# Gmail: enable 2-Step Verification, generate App Password at:
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
# Aliases (same as above)
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here

# Stripe Keys
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Port
PORT=5000

# Cloudinary (for image hosting)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Environment
NODE_ENV=development
