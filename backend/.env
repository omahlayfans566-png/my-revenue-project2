# ─────────────────────────────────────────────────────────────────
#  DateClone Backend — Environment Variables
#  IMPORTANT: Replace placeholder values before running the server
# ─────────────────────────────────────────────────────────────────

# MongoDB — Use MongoDB Atlas (free): https://www.mongodb.com/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dateclone
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/dateclone?retryWrites=true&w=majority

# JWT — Change this to any long random string
JWT_SECRET=dateclone_super_secret_jwt_key_change_in_production_2026

# Gmail — Use an App Password (not your real password)
# Guide: https://support.google.com/accounts/answer/185833
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_16_char_app_password

# Stripe (optional — payment features won't work without this)
STRIPE_PUBLIC_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5174

# Server Port
PORT=5000

# Cloudinary (optional — image uploads won't work without this)
CLOUDINARY_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# Environment
NODE_ENV=development
