# ─────────────────────────────────────────────────────────────────
#  DateClone Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────

# Backend API URL — Vite proxy rewrites /api → localhost:5000/api
# This means you DON'T need CORS issues in development
VITE_API_URL=/api

# App info
VITE_APP_NAME=DateClone
VITE_FRONTEND_URL=http://localhost:5174

# Stripe public key (optional)
VITE_STRIPE_PUBLIC_KEY=pk_test_placeholder

# Feature flags
VITE_ENABLE_EMAIL_VERIFICATION=true
VITE_ENABLE_PREMIUM=true
VITE_ENABLE_MESSAGES=true
